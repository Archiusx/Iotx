rules_version = '2';

// SYNC-OS "FORTRESS" SECURITY ARCHITECTURE
// Evaluates Identity, Integrity, and State through the Eight Pillars of Hardened Rules.
service cloud.firestore {
  match /databases/{database}/documents {

    // PILLAR 0: Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // GLOBAL HELPERS
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // PILLAR 3: Path Variable Hardening (ID Poisoning Guard)
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // VALIDATION BLUEPRINT HELPERS
    // ===============================================================

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'displayName']) 
        && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 100
        && (!('email' in data) || (data.email is string && data.email.size() <= 100))
        && (!('grade' in data) || (data.grade is string && data.grade.size() <= 50))
        && (!('lastActive' in data) || data.lastActive <= request.time);
    }

    function isValidStudyNote(data) {
      return data.keys().hasAll(['uid', 'content'])
        && data.uid == request.auth.uid
        && data.content is string && data.content.size() <= 50000
        && (!('title' in data) || (data.title is string && data.title.size() <= 200))
        && (!('updatedAt' in data) || data.updatedAt <= request.time);
    }

    function isValidLearningModule(data) {
      return data.keys().hasAll(['uid', 'topic', 'type', 'data'])
        && data.uid == request.auth.uid
        && data.topic is string && data.topic.size() <= 200
        && data.type in ['pointwise', 'flashcards', 'test']
        && data.data is map
        && (!('createdAt' in data) || data.createdAt <= request.time);
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['uid', 'subject', 'progress'])
        && data.uid == request.auth.uid
        && data.subject is string && data.subject.size() <= 100
        && data.progress is number && data.progress >= 0 && data.progress <= 100
        && (!('timestamp' in data) || data.timestamp <= request.time);
    }

    // ===============================================================
    // COLLECTION ACCESS RULES
    // ===============================================================

    match /users/{uid} {
      allow get: if isOwner(uid) && isValidId(uid);
      allow create: if isOwner(uid) && isValidId(uid) && isValidUserProfile(incoming())
        && incoming().keys().size() <= 6;
      allow update: if isOwner(uid) && isValidId(uid) && isValidUserProfile(incoming())
        && incoming().uid == existing().uid
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email', 'grade', 'lastActive'])
        );
    }

    match /notes/{noteId} {
      // PILLAR 8: Secure List Queries (Query Enforcer)
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow get: if isSignedIn() && resource.data.uid == request.auth.uid;
      
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid
        && incoming().uid == existing().uid;
        
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /modules/{moduleId} {
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow get: if isSignedIn() && resource.data.uid == request.auth.uid;
      
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid
        && incoming().uid == existing().uid;
        
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /progress/{progressId} {
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow get: if isSignedIn() && resource.data.uid == request.auth.uid;
      
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid
        && incoming().uid == existing().uid;
        
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
