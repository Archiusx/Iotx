rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, displayName, email, grade, lastActive
    //
    // Collection: notes
    // Fields: uid, title, content, updatedAt
    //
    // Collection: modules
    // Fields: uid, topic, type, data, createdAt
    //
    // Collection: progress
    // Fields: uid, subject, progress, timestamp
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ( (request.auth.token.email == "adityadeshakar@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') );
    }

    function isValidString(val, minLen, maxLen) {
      return val is string && val.size() >= minLen && val.size() <= maxLen;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidUser(data) {
      return data.uid is string && 
             data.displayName is string && 
             data.email is string;
    }

    function isValidNote(data) {
      return isValidString(data.content, 1, 10000) &&
             data.uid is string &&
             (!('title' in data) || isValidString(data.title, 0, 500));
    }

    function isValidModule(data) {
      return data.uid is string &&
             data.topic is string &&
             data.type in ['pointwise', 'flashcards', 'test'] &&
             (data.data is map || data.data is list) &&
             (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidProgress(data) {
      return data.uid is string &&
             data.subject is string &&
             data.progress is number &&
             data.progress >= 0 && data.progress <= 1;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if (isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /notes/{noteId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidNote(request.resource.data);
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && isValidNote(request.resource.data) && request.resource.data.uid == resource.data.uid;
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /modules/{moduleId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.uid == request.auth.uid || isAdmin()) && isValidModule(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin()) && isValidModule(request.resource.data) && (request.resource.data.uid == resource.data.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /progress/{progressId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidProgress(request.resource.data);
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && isValidProgress(request.resource.data) && request.resource.data.uid == resource.data.uid;
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }
  }
}
